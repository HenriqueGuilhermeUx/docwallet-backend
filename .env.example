# Render / Flask
PORT=5000
FLASK_DEBUG=false
DATABASE_URL=postgresql://user:password@host:5432/docwallet
JWT_SECRET=troque-por-uma-chave-grande-e-segura
JWT_EXPIRES_HOURS=168
CORS_ORIGINS=https://docwallet.netlify.app,http://localhost:5173

# Storage local no Render Disk
UPLOAD_DIR=/data/uploads
MAX_UPLOAD_MB=25

# Blockchain / cobrança cripto
DOCWALLET_TREASURY_ADDRESS=0xSUA_CARTEIRA_RECEBEDORA
DOCWALLET_CHAIN_ID=137
DOCWALLET_NETWORK_NAME=Polygon
DOCWALLET_RPC_URL=https://polygon-rpc.com
DOCWALLET_EXPLORER_URL=https://polygonscan.com/tx
DOCWALLET_NATIVE_SYMBOL=POL
DOCWALLET_NOTARIZATION_PRICE_NATIVE=0.01
DOCWALLET_REQUIRE_ONCHAIN_VERIFY=true
DOCWALLET_ALLOW_UNVERIFIED_TX=false
